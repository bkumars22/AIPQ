# ── Database ──────────────────────────────────────────────────────
AIPQ_DATABASE_URL=postgresql://aipq:aipq_local_2026@localhost:5433/aipq
POSTGRES_DB=aipq
POSTGRES_USER=aipq
POSTGRES_PASSWORD=change_this_strong_password

# ── LLM providers (deepeval scoring + GEval judge model) ─────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Cache ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── Auth ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=generate_a_64_char_random_hex_string_here
AIPQ_WEBHOOK_SECRET=generate_a_separate_hex_string_here

# ── Observability (optional) ─────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=AIPQ-Production
AIMO_ENDPOINT=

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001

# ── Service URLs (used by backend to reach ai-engine) ────────────
AI_ENGINE_URL=http://localhost:8002
BACKEND_URL=http://localhost:8001
